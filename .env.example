# =============================================================================
# ArrHub — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values.
# Mount your .env into the container with: --env-file /opt/arrhub/.env
# Or pass individual vars with: -e ARRHUB_TOKEN=your-secret
# =============================================================================

# ── Authentication ────────────────────────────────────────────────────────────
# Set a secret token to protect the dashboard (recommended for internet-facing)
# ARRHUB_TOKEN=your-secret-token-here

# Or disable auth entirely for LAN-only / trusted network use
# ARRHUB_NO_AUTH=true

# ── Database ──────────────────────────────────────────────────────────────────
# Path inside the container where SQLite DB is stored.
# Default: /data/arrhub.db — mount /data as a volume to persist settings.
# ARRHUB_DB=/data/arrhub.db

# ── Radarr Integration ────────────────────────────────────────────────────────
# Used by the Overview → Radarr card (upcoming movies calendar)
# RADARR_URL=http://radarr:7878
# RADARR_API_KEY=your-radarr-api-key

# ── Sonarr Integration ────────────────────────────────────────────────────────
# Used by the Overview → Sonarr card (upcoming episode calendar)
# SONARR_URL=http://sonarr:8989
# SONARR_API_KEY=your-sonarr-api-key

# ── Plex Integration ──────────────────────────────────────────────────────────
# Used by the Overview → Plex card (active streams)
# PLEX_URL=http://plex:32400
# PLEX_TOKEN=your-plex-token

# ── Overseerr / Jellyseerr Integration ───────────────────────────────────────
# Used by the Overview → Seerr card (recent media requests)
# SEERR_URL=http://overseerr:5055
# SEERR_API_KEY=your-seerr-api-key

# ── Weather ───────────────────────────────────────────────────────────────────
# Weather settings are configured in the dashboard UI (Settings tab)
# and stored in the SQLite database — no env vars needed.

# =============================================================================
# NOTE: All integration settings can also be configured directly in the
# dashboard Settings tab and are persisted in the SQLite database.
# Environment variables are not required for service integrations.
# =============================================================================
